---
import SiteLayout from "../layouts/SiteLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
---

<SiteLayout title="RedGate-IT | Managed IT Services">
  <Nav />
  <Hero />

  <section class="w-full bg-gradient-to-b from-neutral-900 to-black py-28">
    <div class="mx-auto max-w-6xl px-6 text-left sm:text-center">
      <h2 class="text-3xl font-bold tracking-tight max-w-[70%] sm:max-w-none sm:text-5xl lg:text-6xl">
        RedGate-IT helps small teams modernize their networks,
        improve security, and move confidently to Microsoft 365.
      </h2>
    </div>
  </section>

  <section id="services" class="mx-auto max-w-6xl px-6 pt-25 sm:pt-35 py-16">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Core services</h2>
    <p class="mt-3 max-w-2xl text-white/70">
      Everything you need to run a secure, modern small business — without enterprise complexity.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Managed IT</h3>
        <p class="mt-2 text-white/70">Monitoring, patching, support, and lifecycle planning.</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Cybersecurity</h3>
        <p class="mt-2 text-white/70">MFA, endpoint protection, email security, and policies.</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Microsoft 365</h3>
        <p class="mt-2 text-white/70">Migration, identity, backup, and collaboration setup.</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Network Modernization</h3>
        <p class="mt-2 text-white/70">Ubiquiti design, secure VLANs, Wi-Fi optimization.</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Backup & Recovery</h3>
        <p class="mt-2 text-white/70">Business continuity and ransomware recovery readiness.</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10">
        <h3 class="text-lg font-semibold">Onboarding & Audits</h3>
        <p class="mt-2 text-white/70">Find gaps fast, then fix them with a clear plan.</p>
      </div>
    </div>
  </section>

  <section id="about" class="mx-auto max-w-6xl px-6 py-16">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Built for local businesses</h2>
    <p class="mt-3 max-w-3xl text-white/70">
      RedGate-IT is designed for small teams that want enterprise-grade security, stable networks, and modern collaboration — with friendly support.
    </p>
  </section>

  <section id="contact" class="mx-auto max-w-6xl px-6 py-16">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
      <h2 class="text-2xl font-bold tracking-tight">Talk to RedGate-IT</h2>
      <p class="mt-2 text-white/70">Tell us what you’re using today and what you want to improve.</p>

      <form id="contactForm" class="mt-6">
        <div class="grid gap-3 sm:grid-cols-2">
          <input
            id="name"
            required
            class="w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-white/40"
            placeholder="Name"
          />

          <input
            id="email"
            type="email"
            required
            class="w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-white/40"
            placeholder="Email"
          />

          <input
            id="company"
            class="sm:col-span-2 w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-white/40"
            placeholder="Company (optional)"
          />

          <textarea
            id="message"
            required
            class="sm:col-span-2 min-h-[120px] w-full rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white placeholder:text-white/40"
            placeholder="What do you need help with?"
          ></textarea>
        </div>

        <!-- Turnstile -->
        <div class="mt-4">
          <div
            class="cf-turnstile"
            data-sitekey="0x4AAAAAACiUq94vEPkE1FRE"
            data-theme="dark"
          ></div>
        </div>

        <button
          type="submit"
          class="mt-5 rounded-md bg-[#a0001c] px-5 py-3 font-semibold hover:bg-red-500"
        >
          Request a consultation
        </button>

        <p id="formStatus" class="mt-3 text-sm text-white/50"></p>
      </form>
    </div>

    <footer class="mt-12 text-sm text-white/50">
      © {new Date().getFullYear()} RedGate-IT. All rights reserved.
    </footer>
  </section>

  <!-- Turnstile script -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contactForm");
    const status = document.getElementById("formStatus");

    if (!form || !status) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.textContent = "Sending...";

      const nameEl = document.getElementById("name");
      const emailEl = document.getElementById("email");
      const companyEl = document.getElementById("company");
      const messageEl = document.getElementById("message");

      if (!nameEl || !emailEl || !companyEl || !messageEl) {
        status.textContent = "Form error: missing fields.";
        return;
      }

      const tokenEl = form.querySelector('input[name="cf-turnstile-response"]');
      const turnstileToken = tokenEl ? tokenEl.value : "";

      if (!turnstileToken) {
        status.textContent = "Please complete the verification and try again.";
        return;
      }

      const payload = {
        name: nameEl.value,
        email: emailEl.value,
        company: companyEl.value,
        message: messageEl.value,
        turnstileToken,
      };

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          status.textContent = "Sent! We’ll reply within 1 business day.";
          form.reset();
          if (window.turnstile) window.turnstile.reset();
        } else {
          status.textContent = "Something went wrong. Please try again.";
          if (window.turnstile) window.turnstile.reset();
        }
      } catch (err) {
        status.textContent = "Network error. Please try again.";
        if (window.turnstile) window.turnstile.reset();
      }
    });
  });
  </script>
</SiteLayout>